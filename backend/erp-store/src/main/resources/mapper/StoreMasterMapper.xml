<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.jp.store.mapper.StoreMasterMapper">

    <resultMap id="BaseResultMap" type="com.erp.jp.store.entity.StoreMaster">
        <id column="id" property="id"/>
        <result column="tenant_id" property="tenantId"/>
        <result column="store_name" property="storeName"/>
        <result column="platform_code" property="platformCode"/>
        <result column="seller_id" property="sellerId"/>
        <result column="auth_status" property="authStatus"/>
        <result column="is_sandbox" property="isSandbox"/>
        <result column="group_id" property="groupId"/>
        <result column="manager_id" property="managerId"/>
        <result column="region_code" property="regionCode"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="is_deleted" property="isDeleted"/>
    </resultMap>

    <select id="selectStoreListWithAuth" resultMap="BaseResultMap">
        SELECT s.* FROM t_store_master s
        LEFT JOIN t_store_auth_info a ON s.id = a.store_id
        WHERE s.tenant_id = #{tenantId} AND s.is_deleted = 0
        <if test="platformCode != null and platformCode != '' and platformCode != 'all'">
            AND s.platform_code = #{platformCode}
        </if>
        ORDER BY s.create_time DESC
    </select>
</mapper>
